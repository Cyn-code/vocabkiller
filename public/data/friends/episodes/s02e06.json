  "lines": [
    {
      "type": "scene",
      "text": "[Scene: At Monica and Rachel's.]"
    },
    {
      "type": "dialogue",
      "speakerLabel": "MONICA",
      "speakerIds": [
        "monica"
      ],
      "text": "Who da wenny-Benny boy? You the Wenny-wenny-Benny-Benny boy, yes. Don't cry. Don't cry. Why is he still crying?"
    },
    {
      "type": "dialogue",
      "speakerLabel": "ROSS",
      "speakerIds": [
        "ross"
      ],
      "text": "Let me hold him for a sec. There. (Ben stops crying) Huh? There we are."
    },
    {
      "type": "dialogue",
      "speakerLabel": "MONICA",
      "speakerIds": [
        "monica"
      ],
      "text": "Maye it's me."
    },
    {
      "type": "dialogue",
      "speakerLabel": "ROSS",
      "speakerIds": [
        "ross"
      ],
      "text": "Don't be silly. Ben loves you. He's just being Mr. Crankypants."
    },
    {
      "type": "dialogue",
      "speakerLabel": "CHANDLER",
      "speakerIds": [
        "chandler"
      ],
      "text": "You know, I once dated a Miss Crankypants. Lovely girl, kinda moody."
    },
    {
      "type": "dialogue",
      "speakerLabel": "ROSS",
      "speakerIds": [
        "ross"
      ],
      "text": "There we go. All better. (gives Ben back to Monica)"
    },
    {
      "type": "dialogue",
      "speakerLabel": "MONICA",
      "speakerIds": [
        "monica"
      ],
      "text": "There's my little boy. (Ben starts crying again)"
    },
    {
      "type": "dialogue",
      "speakerLabel": "CHANDLER",
      "speakerIds": [
        "chandler"
      ],
      "text": "Can I uh see something? (Takes Ben. When he puts him close to Monica, Ben cries. When he moves Ben away, he stops crying.)"
    },
    {
      "type": "dialogue",
      "speakerLabel": "JOEY",
      "speakerIds": [
        "joey"
      ],
      "text": "Cool."
    },
    {
      "type": "dialogue",
      "speakerLabel": "MONICA",
      "speakerIds": [
        "monica"
      ],
      "text": "He hates me. My nephew hates me."
    },
    {
      "type": "dialogue",
      "speakerLabel": "ROSS",
      "speakerIds": [
        "ross"
      ],
      "text": "Come on, don't do this."
    },
    {
      "type": "dialogue",
      "speakerLabel": "MONICA",
      "speakerIds": [
        "monica"
      ],
      "text": "What if my own baby hates me? Huh? What am I gonna do then?"
    },
    {
      "type": "dialogue",
      "speakerLabel": "CHANDLER",
      "speakerIds": [
        "chandler"
      ],
      "text": "Monica, will you stop? This is nuts. Do you know how long it's gonna be before you actually have to deal with this problem? I mean, you don't even have a boyfriend yet. Joey, she does not look fat."
    },
    {
      "type": "action",
      "text": "(Chandler has a basketball which he is moving closer to, then away from, Monica)"
    },
    {
      "type": "dialogue",
      "speakerLabel": "JOEY",
      "speakerIds": [
        "joey"
      ],
      "text": "Goo, goo, goo, waaah!"
    },
    {
      "type": "dialogue",
      "speakerLabel": "MONICA",
      "speakerIds": [
        "monica"
      ],
      "text": "That is so funny. Let me see that. (throws the ball out the window)"
    },
    {
      "type": "dialogue",
      "speakerLabel": "JOEY",
      "speakerIds": [
        "joey"
      ],
      "text": "Are you ok, Ross?"
    },
    {
      "type": "dialogue",
      "speakerLabel": "ROSS",
      "speakerIds": [
        "ross"
      ],
      "text": "I don't know. What's in this pie?"
    },
    {
      "type": "dialogue",
      "speakerLabel": "MONICA",
      "speakerIds": [
        "monica"
      ],
      "text": "Uh, I don't know, butter, eggs, flour, lime, kiwi--"
    },
    {
      "type": "dialogue",
      "speakerLabel": "ROSS",
      "speakerIds": [
        "ross"
      ],
      "text": "Kiwi? Kiwi? I thought it was a key lime pie."
    },
    {
      "type": "dialogue",
      "speakerLabel": "MONICA",
      "speakerIds": [
        "monica"
      ],
      "text": "No I didn't, I said kiwi lime. That's what makes it so special."
    },
    {
      "type": "dialogue",
      "speakerLabel": "ROSS",
      "speakerIds": [
        "ross"
      ],
      "text": "And that's what's gonna kill me. I'm allergic to kiwi."
    },
    {
      "type": "dialogue",
      "speakerLabel": "MONICA",
      "speakerIds": [
        "monica"
      ],
      "text": "No you're not. You're, you're allergic to lobster and peanuts and--oh my god."
    },
    {
      "type": "dialogue",
      "speakerLabel": "ROSS",
      "speakerIds": [
        "ross"
      ],
      "text": "Ugh."
    },
    {
      "type": "dialogue",
      "speakerLabel": "MONICA",
      "speakerIds": [
        "monica"
      ],
      "text": "Oh my god."
    },
    {
      "type": "dialogue",
      "speakerLabel": "ROSS",
      "speakerIds": [
        "ross"
      ],
      "text": "Ugh. It's definitely getting worse."
    },
    {
      "type": "dialogue",
      "speakerLabel": "MONICA",
      "speakerIds": [
        "monica"
      ],
      "text": "Is your tongue swelling up?"
    },
    {
      "type": "dialogue",
      "speakerLabel": "ROSS",
      "speakerIds": [
        "ross"
      ],
      "text": "Either that or my mouth is getting smaller."
    },
    {
      "type": "dialogue",
      "speakerLabel": "MONICA",
      "speakerIds": [
        "monica"
      ],
      "text": "All right, get your coat, we're going to the hospital."
    },
    {
      "type": "dialogue",
      "speakerLabel": "JOEY",
      "speakerIds": [
        "joey"
      ],
      "text": "Is he gonna be ok?"
    },
    {
      "type": "dialogue",
      "speakerLabel": "MONICA",
      "speakerIds": [
        "monica"
      ],
      "text": "Yeah, he's just gotta get a shot."
    },
    {
      "type": "dialogue",
      "speakerLabel": "ROSS",
      "speakerIds": [
        "ross"
      ],
      "text": "You know, you know, actually it's getting better. It is. It is. Let's not go. Anyone for Thcrabble?"
    },
    {
      "type": "dialogue",
      "speakerLabel": "MONICA",
      "speakerIds": [
        "monica"
      ],
      "text": "Jacket now."
    },
    {
      "type": "dialogue",
      "speakerLabel": "ROSS",
      "speakerIds": [
        "ross"
      ],
      "text": "What about Ben? We can't bring a baby to a hospital."
    },
    {
      "type": "dialogue",
      "speakerLabel": "CHANDLER",
      "speakerIds": [
        "chandler"
      ],
      "text": "We'll watch him."
    },
    {
      "type": "dialogue",
      "speakerLabel": "ROSS",
      "speakerIds": [
        "ross"
      ],
      "text": "I don't think tho."
    },
    {
      "type": "dialogue",
      "speakerLabel": "JOEY",
      "speakerIds": [
        "joey"
      ],
      "text": "What? I have seven Catholic sisters. I've taken care of hundreds of kids. Come on, we wanna do it, don't we?"
    },
    {
      "type": "dialogue",
      "speakerLabel": "CHANDLER",
      "speakerIds": [
        "chandler"
      ],
      "text": "I was looking forward to playing basketball, but I guess that's out the window."
    },
    {
      "type": "dialogue",
      "speakerLabel": "ROSS",
      "speakerIds": [
        "ross"
      ],
      "text": "Ok, well, if you do take him out for his walk, you might wanna bring his hat, and there's extra milk in the fridge, and there's extra diapers in the bag."
    },
    {
      "type": "dialogue",
      "speakerLabel": "JOEY",
      "speakerIds": [
        "joey"
      ],
      "text": "Hat, milk, got it."
    },
    {
      "type": "dialogue",
      "speakerLabel": "ROSS",
      "speakerIds": [
        "ross"
      ],
      "text": "??? (speech garbled) Thro up a thro thro--a thro thro!"
    },
    {
      "type": "dialogue",
      "speakerLabel": "JOEY",
      "speakerIds": [
        "joey"
      ],
      "text": "Consider it done."
    },
    {
      "type": "dialogue",
      "speakerLabel": "CHANDLER",
      "speakerIds": [
        "chandler"
      ],
      "text": "You understood that?"
    },
    {
      "type": "dialogue",
      "speakerLabel": "JOEY",
      "speakerIds": [
        "joey"
      ],
      "text": "Yeah, my uncle Sal has a really big tongue."
    },
    {
      "type": "dialogue",
      "speakerLabel": "CHANDLER",
      "speakerIds": [
        "chandler"
      ],
      "text": "Is he the one with the beautiful wife?"
    },
    {
      "type": "action",
      "text": "(Central Perk)"
    },
    {
      "type": "dialogue",
      "speakerLabel": "PHOEBE",
      "speakerIds": [
        "phoebe"
      ],
      "text": "Hey Rach, wanna hear the new song I'm thinkin' of singing this afternoon? I wrote it this morning in the shower."
    },
    {
      "type": "dialogue",
      "speakerLabel": "RACHEL",
      "speakerIds": [
        "rachel"
      ],
      "text": "Ok."
    },
    {
      "type": "dialogue",
      "speakerLabel": "PHOEBE",
      "speakerIds": [
        "phoebe"
      ],
      "text": "(singing) I'm in the shower and I'm writing a song. Stop me if you've heard it. My skin is soapy, and my hair is wet, and Tegrin spelled backward is Nirget."
    },
    {
      "type": "dialogue",
      "speakerLabel": "TERRY",
      "speakerIds": [
        "terry"
      ],
      "text": "Uh, Rachel, sweetheart, could I see ya for a minute?"
    },
    {
      "type": "dialogue",
      "speakerLabel": "RACHEL",
      "speakerIds": [
        "rachel"
      ],
      "text": "What's up?"
    },
    {
      "type": "dialogue",
      "speakerLabel": "TERRY",
      "speakerIds": [
        "terry"
      ],
      "text": "F.Y.I.. I've decided to pay a professional musician to play in here on Sunday afternoons. Her name is Stephanie... something. She's supposed to be very good."
    },
    {
      "type": "dialogue",
      "speakerLabel": "RACHEL",
      "speakerIds": [
        "rachel"
      ],
      "text": "But what about Phoebe?"
    },
    {
      "type": "dialogue",
      "speakerLabel": "TERRY",
      "speakerIds": [
        "terry"
      ],
      "text": "Rachel, it's not that your friend is bad, it's that she's so bad, she makes me want to put my finger through my eye into my brain and swirl it around."
    },
    {
      "type": "dialogue",
      "speakerLabel": "RACHEL",
      "speakerIds": [
        "rachel"
      ],
      "text": "Ok, ok, so you're not a fan, but I mean, come on, you cannot do this to her."
    },
    {
      "type": "dialogue",
      "speakerLabel": "TERRY",
      "speakerIds": [
        "terry"
      ],
      "text": "Uh--"
    },
    {
      "type": "dialogue",
      "speakerLabel": "RACHEL",
      "speakerIds": [
        "rachel"
      ],
      "text": "Oh, no no no no. Oh no no no no. I have to do this to her?"
    },
    {
      "type": "dialogue",
      "speakerLabel": "PHOEBE",
      "speakerIds": [
        "phoebe"
      ],
      "text": "(singing) Lather, rinse, repeat, and lather, rinse, repeat, and lather, rinse, repeat, as needed."
    },
    {
      "type": "action",
      "text": "(Chandler and Joey are loaded down with baby stuff, and Ben)"
    },
    {
      "type": "dialogue",
      "speakerLabel": "CHANDLER",
      "speakerIds": [
        "chandler"
      ],
      "text": "You know, I don't think we brought enough stuff. Did you forget to pack the baby's anvil?"
    },
    {
      "type": "dialogue",
      "speakerLabel": "JOEY",
      "speakerIds": [
        "joey"
      ],
      "text": "It's gonna be worth it. It's a known fact that women love babies, all righ? Women love guys who love babies. It's that whole sensitive thing. Quick, aim him at that pack o' babes over there. Maybe one of them will break away. No, no wait, for get them, we got one, hard left. All right, gimme the baby."
    },
    {
      "type": "dialogue",
      "speakerLabel": "CHANDLER",
      "speakerIds": [
        "chandler"
      ],
      "text": "No, I got him."
    },
    {
      "type": "dialogue",
      "speakerLabel": "JOEY",
      "speakerIds": [
        "joey"
      ],
      "text": "No, seriously."
    },
    {
      "type": "dialogue",
      "speakerLabel": "CHANDLER",
      "speakerIds": [
        "chandler"
      ],
      "text": "Oh, seriously you want him?"
    },
    {
      "type": "dialogue",
      "speakerLabel": "CAROLINE",
      "speakerIds": [
        "caroline"
      ],
      "text": "Hello."
    },
    {
      "type": "dialogue",
      "speakerLabel": "BOYS",
      "speakerIds": [
        "boys"
      ],
      "text": "Hello."
    },
    {
      "type": "dialogue",
      "speakerLabel": "CAROLINE",
      "speakerIds": [
        "caroline"
      ],
      "text": "And who is this little cutie pie?"
    },
    {
      "type": "dialogue",
      "speakerLabel": "CHANDLER",
      "speakerIds": [
        "chandler"
      ],
      "text": "Well, don't, don't think me immodest, but, me?"
    },
    {
      "type": "dialogue",
      "speakerLabel": "JOEY",
      "speakerIds": [
        "joey"
      ],
      "text": "You wanna smell him?"
    },
    {
      "type": "dialogue",
      "speakerLabel": "CAROLINE",
      "speakerIds": [
        "caroline"
      ],
      "text": "I assume we're talking about the baby now."
    },
    {
      "type": "dialogue",
      "speakerLabel": "JOEY",
      "speakerIds": [
        "joey"
      ],
      "text": "Oh, yeah. He's got that great baby smell. Get a whiff of his head."
    },
    {
      "type": "dialogue",
      "speakerLabel": "CAROLINE",
      "speakerIds": [
        "caroline"
      ],
      "text": "I think my uterus just skipped a beat."
    },
    {
      "type": "dialogue",
      "speakerLabel": "JOEY",
      "speakerIds": [
        "joey"
      ],
      "text": "(to Chandler) What'd I tell you? What'd I tell you?"
    },
    {
      "type": "dialogue",
      "speakerLabel": "CAROLINE",
      "speakerIds": [
        "caroline"
      ],
      "text": "I think it's great you guys are doing this."
    },
    {
      "type": "dialogue",
      "speakerLabel": "CHANDLER",
      "speakerIds": [
        "chandler"
      ],
      "text": "Well, we are great guys."
    },
    {
      "type": "dialogue",
      "speakerLabel": "CAROLINE",
      "speakerIds": [
        "caroline"
      ],
      "text": "You know, my brother and his boyfriend have been trying to adopt for three years. What agency did you two go through?"
    },
    {
      "type": "action",
      "text": "(Central Perk)"
    },
    {
      "type": "dialogue",
      "speakerLabel": "PHOEBE",
      "speakerIds": [
        "phoebe"
      ],
      "text": "But, but this is my gig. This is where I play. My, my name is written out there in chalk. You know, you can't just erase chalk."
    },
    {
      "type": "dialogue",
      "speakerLabel": "RACHEL",
      "speakerIds": [
        "rachel"
      ],
      "text": "Honey, I'm sorry."
    },
    {
      "type": "dialogue",
      "speakerLabel": "PHOEBE",
      "speakerIds": [
        "phoebe"
      ],
      "text": "And he's going to be paying this woman? Why doesn't he just give her like a throne, and a crown, and like a, you know, gold stick with a ball on top."
    },
    {
      "type": "dialogue",
      "speakerLabel": "RACHEL",
      "speakerIds": [
        "rachel"
      ],
      "text": "Terry is a jerk, ok? That's why we're always saying \"Terry's a jerk!\" That's where that came from."
    },
    {
      "type": "dialogue",
      "speakerLabel": "PHOEBE",
      "speakerIds": [
        "phoebe"
      ],
      "text": "Yeah, ok. You probably did everything you could."
    },
    {
      "type": "dialogue",
      "speakerLabel": "RACHEL",
      "speakerIds": [
        "rachel"
      ],
      "text": "Ok, you know what, lemme, let me just see what else I can do. All right, look, look. Why don't you just let her go on after Stephanie whatever-her-name-is. I mean, you won't even be here. You don't pay her. It's not gonna cost you anything."
    },
    {
      "type": "dialogue",
      "speakerLabel": "TERRY",
      "speakerIds": [
        "terry"
      ],
      "text": "I, I don't know."
    },
    {
      "type": "dialogue",
      "speakerLabel": "RACHEL",
      "speakerIds": [
        "rachel"
      ],
      "text": "Come on, Terry, I'll even clean the cappuccino machine."
    },
    {
      "type": "dialogue",
      "speakerLabel": "TERRY",
      "speakerIds": [
        "terry"
      ],
      "text": "You don't clean the cappuccino machine?"
    },
    {
      "type": "dialogue",
      "speakerLabel": "RACHEL",
      "speakerIds": [
        "rachel"
      ],
      "text": "Of course I clean it. I mean, I,I will cleeeean it. I mean, I will cleeeean it."
    },
    {
      "type": "dialogue",
      "speakerLabel": "TERRY",
      "speakerIds": [
        "terry"
      ],
      "text": "Oh, all right, fine, fine, fine."
    },
    {
      "type": "dialogue",
      "speakerLabel": "RACHEL",
      "speakerIds": [
        "rachel"
      ],
      "text": "Done."
    },
    {
      "type": "dialogue",
      "speakerLabel": "PHOEBE",
      "speakerIds": [
        "phoebe"
      ],
      "text": "Really?"
    },
    {
      "type": "dialogue",
      "speakerLabel": "RACHEL",
      "speakerIds": [
        "rachel"
      ],
      "text": "Yeah. Who's workin' for you babe?"
    },
    {
      "type": "dialogue",
      "speakerLabel": "PHOEBE",
      "speakerIds": [
        "phoebe"
      ],
      "text": "Oh! Oh my god. This is so exciting. How much am I gonna get?"
    },
    {
      "type": "dialogue",
      "speakerLabel": "RACHEL",
      "speakerIds": [
        "rachel"
      ],
      "text": "What?"
    },
    {
      "type": "dialogue",
      "speakerLabel": "PHOEBE",
      "speakerIds": [
        "phoebe"
      ],
      "text": "Well you said that he's paying the people who are playing."
    },
    {
      "type": "dialogue",
      "speakerLabel": "RACHEL",
      "speakerIds": [
        "rachel"
      ],
      "text": "Oh, no, no no. I meant that he's gonna be paying that other woman beause she's a professional."
    },
    {
      "type": "dialogue",
      "speakerLabel": "PHOEBE",
      "speakerIds": [
        "phoebe"
      ],
      "text": "Well, I'm not gonna be the only one who's not getting paid."
    },
    {
      "type": "dialogue",
      "speakerLabel": "RACHEL",
      "speakerIds": [
        "rachel"
      ],
      "text": "Well, but Pheebs."
    },
    {
      "type": "dialogue",
      "speakerLabel": "PHOEBE",
      "speakerIds": [
        "phoebe"
      ],
      "text": "No, huh uh, I'm sorry, no. No, I'm not some like sloppy second, charity band. You know what, there are thousands of places in this city where people would be happy to pay to hear me play. (Out on the sidewalk, singing) When I play, I play for me, I don't need your charity. (Someone puts a coin in her guitar case) Thank you! La la la la la la la...."
    },
    {
      "type": "dialogue",
      "speakerLabel": "ROSS",
      "speakerIds": [
        "ross"
      ],
      "text": "Well, there's no way I'm gonna get a shot. Maybe they can take the needle and thquirt it into my mouth, you know, like a thquirt gun."
    },
    {
      "type": "dialogue",
      "speakerLabel": "DOCTOR",
      "speakerIds": [
        "doctor"
      ],
      "text": "Hello, there. I'm Dr. Carlin. I see someone's having an allergic reaction."
    },
    {
      "type": "dialogue",
      "speakerLabel": "MONICA",
      "speakerIds": [
        "monica"
      ],
      "text": "Doctor, can I see you for just a minute please? My brother has a slight phobia about needles."
    },
    {
      "type": "dialogue",
      "speakerLabel": "ROSS",
      "speakerIds": [
        "ross"
      ],
      "text": "Did you tell him about my thquirt gun idea?"
    },
    {
      "type": "dialogue",
      "speakerLabel": "MONICA",
      "speakerIds": [
        "monica"
      ],
      "text": "My brother, the PhD would like to know if there's any way to treat this orally."
    },
    {
      "type": "dialogue",
      "speakerLabel": "DOCTOR",
      "speakerIds": [
        "doctor"
      ],
      "text": "No, under these circumstances it has to be an injection, and it has to be now."
    },
    {
      "type": "dialogue",
      "speakerLabel": "ROSS",
      "speakerIds": [
        "ross"
      ],
      "text": "Tho?"
    },
    {
      "type": "action",
      "text": "(Monica shakes her head.)"
    },
    {
      "type": "dialogue",
      "speakerLabel": "ROSS",
      "speakerIds": [
        "ross"
      ],
      "text": "Ohhh."
    },
    {
      "type": "dialogue",
      "speakerLabel": "MONICA",
      "speakerIds": [
        "monica"
      ],
      "text": "That's good, have a seat. Um, the doctor says it's gotta be a needle. You're just gonna have to be brave, ok? Can you do that for me?"
    },
    {
      "type": "dialogue",
      "speakerLabel": "ROSS",
      "speakerIds": [
        "ross"
      ],
      "text": "Ok."
    },
    {
      "type": "dialogue",
      "speakerLabel": "MONICA",
      "speakerIds": [
        "monica"
      ],
      "text": "Ok. Oh boy. You are doin' so good. You wanna squeeze my hand? All right, Ross, don't squeeze it so hard. Honey, really, don't squeeze it so hard! Oh, Ross! Let go of my hand!"
    },
    {
      "type": "dialogue",
      "speakerLabel": "CHANDLER",
      "speakerIds": [
        "chandler"
      ],
      "text": "That's a good plan, Joe. Next time we wanna pick up women, we should just go to the park and make out. Taxi, taxi!"
    },
    {
      "type": "dialogue",
      "speakerLabel": "JOEY",
      "speakerIds": [
        "joey"
      ],
      "text": "Hey, hey, look at that talent."
    },
    {
      "type": "dialogue",
      "speakerLabel": "CHANDLER",
      "speakerIds": [
        "chandler"
      ],
      "text": "(to taxi driver) Just practicing. You're good. Carry on."
    },
    {
      "type": "dialogue",
      "speakerLabel": "GIRL 1 ON BUS",
      "speakerIds": [
        "girl-1-on-bus"
      ],
      "text": "Hey, you. He's just adorable."
    },
    {
      "type": "dialogue",
      "speakerLabel": "CHANDLER",
      "speakerIds": [
        "chandler"
      ],
      "text": "Ok, but can you tell him that, because he thinks he's too pink."
    },
    {
      "type": "dialogue",
      "speakerLabel": "GIRL 2 ON BUS",
      "speakerIds": [
        "girl-2-on-bus"
      ],
      "text": "So what are you guys out doing today?"
    },
    {
      "type": "dialogue",
      "speakerLabel": "JOEY",
      "speakerIds": [
        "joey"
      ],
      "text": "Oh we're not out. No, no. We're just uh, two heterosexual guys, hanging with the son of our other heterosexual friend, doin' the usual straight guy stuff."
    },
    {
      "type": "dialogue",
      "speakerLabel": "CHANDLER",
      "speakerIds": [
        "chandler"
      ],
      "text": "You done?"
    },
    {
      "type": "dialogue",
      "speakerLabel": "JOEY",
      "speakerIds": [
        "joey"
      ],
      "text": "Yeah."
    },
    {
      "type": "dialogue",
      "speakerLabel": "GIRL 1",
      "speakerIds": [
        "girl-1"
      ],
      "text": "Oh, there's our stop."
    },
    {
      "type": "dialogue",
      "speakerLabel": "JOEY",
      "speakerIds": [
        "joey"
      ],
      "text": "Get outta here. This is our stop too."
    },
    {
      "type": "dialogue",
      "speakerLabel": "GIRL 2",
      "speakerIds": [
        "girl-2"
      ],
      "text": "You guys live around here too?"
    },
    {
      "type": "dialogue",
      "speakerLabel": "JOEY",
      "speakerIds": [
        "joey"
      ],
      "text": "Oh, yeah, yeah, sure. We live in the building by the uh sidewalk."
    },
    {
      "type": "dialogue",
      "speakerLabel": "CHANDLER",
      "speakerIds": [
        "chandler"
      ],
      "text": "You know it?"
    },
    {
      "type": "dialogue",
      "speakerLabel": "JOEY",
      "speakerIds": [
        "joey"
      ],
      "text": "Hey, look, since we're neighbors and all, what do you say we uh, get together for a drink?"
    },
    {
      "type": "dialogue",
      "speakerLabel": "GIRL 1",
      "speakerIds": [
        "girl-1"
      ],
      "text": "So uh, you wanna go to Marquel's?"
    },
    {
      "type": "dialogue",
      "speakerLabel": "CHANDLER",
      "speakerIds": [
        "chandler"
      ],
      "text": "Oh, sure, they love us over there."
    },
    {
      "type": "dialogue",
      "speakerLabel": "GIRL 2",
      "speakerIds": [
        "girl-2"
      ],
      "text": "Where's your baby?"
    },
    {
      "type": "dialogue",
      "speakerLabel": "CHANDLER AND JOEY",
      "speakerIds": [
        "chandler",
        "joey"
      ],
      "text": "(running after bus) Ben! Ben! Ben!"
    },
    {
      "type": "dialogue",
      "speakerLabel": "CHANDLER",
      "speakerIds": [
        "chandler"
      ],
      "text": "Oh, that's good. Maybe he'll hear you and pull the cord."
    },
    {
      "type": "dialogue",
      "speakerLabel": "BOTH",
      "speakerIds": [
        "both"
      ],
      "text": "Stop the bus! Wait! Wait! Wait!"
    },
    {
      "type": "dialogue",
      "speakerLabel": "MONICA",
      "speakerIds": [
        "monica"
      ],
      "text": "Are you sure he didn't break it because it really hurts."
    },
    {
      "type": "dialogue",
      "speakerLabel": "DOCTOR",
      "speakerIds": [
        "doctor"
      ],
      "text": "No, it's just a good bone bruise. And, right here is the puncture wound from your ring."
    },
    {
      "type": "dialogue",
      "speakerLabel": "ROSS",
      "speakerIds": [
        "ross"
      ],
      "text": "Oh, I'm sorry, I'm really sorry. Sorry. Sorry! Hey! Hey! I got my s's back! Which we can celebrate later. Celebrate."
    },
    {
      "type": "dialogue",
      "speakerLabel": "PHOEBE",
      "speakerIds": [
        "phoebe"
      ],
      "text": "(singing) ... with the double double double-jointed boy. Hey. So um, are you the professional guitar player?"
    },
    {
      "type": "dialogue",
      "speakerLabel": "STEPHANIE",
      "speakerIds": [
        "stephanie"
      ],
      "text": "Yeah. I'm Stephanie."
    },
    {
      "type": "dialogue",
      "speakerLabel": "PHOEBE",
      "speakerIds": [
        "phoebe"
      ],
      "text": "Right. My name was on there, but now it just says \"carrot cake\". So, um, so um, how many chords do you know?"
    },
    {
      "type": "dialogue",
      "speakerLabel": "STEPHANIE",
      "speakerIds": [
        "stephanie"
      ],
      "text": "All of them."
    },
    {
      "type": "dialogue",
      "speakerLabel": "PHOEBE",
      "speakerIds": [
        "phoebe"
      ],
      "text": "Oh yeah, so you know D?"
    },
    {
      "type": "dialogue",
      "speakerLabel": "STEPHANIE",
      "speakerIds": [
        "stephanie"
      ],
      "text": "Yeah."
    },
    {
      "type": "dialogue",
      "speakerLabel": "PHOEBE",
      "speakerIds": [
        "phoebe"
      ],
      "text": "Ok, do you know A minor?"
    },
    {
      "type": "dialogue",
      "speakerLabel": "STEPHANIE",
      "speakerIds": [
        "stephanie"
      ],
      "text": "Yeah."
    },
    {
      "type": "dialogue",
      "speakerLabel": "PHOEBE",
      "speakerIds": [
        "phoebe"
      ],
      "text": "Ok, do you know how to go from D to A minor?"
    },
    {
      "type": "dialogue",
      "speakerLabel": "STEPHANIE",
      "speakerIds": [
        "stephanie"
      ],
      "text": "Yeah."
    },
    {
      "type": "dialogue",
      "speakerLabel": "PHOEBE",
      "speakerIds": [
        "phoebe"
      ],
      "text": "Ok. Um, so does your guitar have a strap?"
    },
    {
      "type": "dialogue",
      "speakerLabel": "STEPHANIE",
      "speakerIds": [
        "stephanie"
      ],
      "text": "No."
    },
    {
      "type": "dialogue",
      "speakerLabel": "PHOEBE",
      "speakerIds": [
        "phoebe"
      ],
      "text": "Oh. Mine does. (singing) Stephanie knows all the chords. (makes a face)"
    },
    {
      "type": "dialogue",
      "speakerLabel": "CHANDLER",
      "speakerIds": [
        "chandler"
      ],
      "text": "(on pay phone) Come on, pick up, pick up! Hello? Transit Authority? Yes, hello. I'm doing research for a book, and I was wondering what someone might do if they left a baby on a city bus. Yes I do realize that would be a very stupid charact er."
    },
    {
      "type": "dialogue",
      "speakerLabel": "JOEY",
      "speakerIds": [
        "joey"
      ],
      "text": "Hi, here's the deal. We lost a carseat on a bus today. It's white plastic, with a handle, and it fits onto a stroller. Oh, and there was a baby in it. He wants to talk to you again."
    },
    {
      "type": "dialogue",
      "speakerLabel": "RACHEL",
      "speakerIds": [
        "rachel"
      ],
      "text": "Ok, everybody, let's give a uh nice warm Central Perk welcome to--"
    },
    {
      "type": "dialogue",
      "speakerLabel": "PHOEBE",
      "speakerIds": [
        "phoebe"
      ],
      "text": "(singing angrily) Terry's a jerk, and he won't let me work, and I hate Central Perk!"
    },
    {
      "type": "dialogue",
      "speakerLabel": "RACHEL",
      "speakerIds": [
        "rachel"
      ],
      "text": "Uh, to Stephanie Schiffer."
    },
    {
      "type": "dialogue",
      "speakerLabel": "STEPHANIE",
      "speakerIds": [
        "stephanie"
      ],
      "text": "Thank you. I'd like to start with a song that I wrote for the first man I ever loved. (singing) Zachary."
    },
    {
      "type": "dialogue",
      "speakerLabel": "PHOEBE",
      "speakerIds": [
        "phoebe"
      ],
      "text": "(singing/screaming) You're all invited to bite me!"
    },
    {
      "type": "dialogue",
      "speakerLabel": "CHANDLER AND JOEY",
      "speakerIds": [
        "chandler",
        "joey"
      ],
      "text": "Hi. We're the guys who called about the baby. We left the baby on ths bus. Is he here? Is he here?"
    },
    {
      "type": "dialogue",
      "speakerLabel": "TRANSIT AUTHORITY GUY",
      "speakerIds": [
        "transit-authority-guy"
      ],
      "text": "He's here. (Chandler and Joey hug each other in relief) I'm assuming one of you is the father."
    },
    {
      "type": "dialogue",
      "speakerLabel": "CHANDLER",
      "speakerIds": [
        "chandler"
      ],
      "text": "That's me."
    },
    {
      "type": "dialogue",
      "speakerLabel": "JOEY",
      "speakerIds": [
        "joey"
      ],
      "text": "I'm him."
    },
    {
      "type": "dialogue",
      "speakerLabel": "CHANDLER",
      "speakerIds": [
        "chandler"
      ],
      "text": "Actually, uh, we're both the father. (Puts his arm around Joey)"
    },
    {
      "type": "dialogue",
      "speakerLabel": "BOTH (but to different babies)",
      "speakerIds": [
        "both-but-to-different-babies"
      ],
      "text": "Oh, Ben! Hey, buddy!"
    },
    {
      "type": "dialogue",
      "speakerLabel": "CHANDLER",
      "speakerIds": [
        "chandler"
      ],
      "text": "Please tell me you know which one is our baby."
    },
    {
      "type": "dialogue",
      "speakerLabel": "JOEY",
      "speakerIds": [
        "joey"
      ],
      "text": "Well, well that one has ducks on his t-shirt, and this one has clowns. And Ben was definitely wearing ducks."
    },
    {
      "type": "dialogue",
      "speakerLabel": "CHANDLER",
      "speakerIds": [
        "chandler"
      ],
      "text": "Ok."
    },
    {
      "type": "dialogue",
      "speakerLabel": "JOEY",
      "speakerIds": [
        "joey"
      ],
      "text": "Or clowns. Oh, oh wait. That one's definitely Ben. Remember, he had that cute little mole by his mouth."
    },
    {
      "type": "dialogue",
      "speakerLabel": "CHANDLER",
      "speakerIds": [
        "chandler"
      ],
      "text": "Yeah?"
    },
    {
      "type": "dialogue",
      "speakerLabel": "JOEY",
      "speakerIds": [
        "joey"
      ],
      "text": "Yeah."
    },
    {
      "type": "dialogue",
      "speakerLabel": "CHANDLER",
      "speakerIds": [
        "chandler"
      ],
      "text": "Hey, Ben, remember us? Ok, the mole came off."
    },
    {
      "type": "dialogue",
      "speakerLabel": "JOEY",
      "speakerIds": [
        "joey"
      ],
      "text": "Ahh!"
    },
    {
      "type": "dialogue",
      "speakerLabel": "CHANDLER",
      "speakerIds": [
        "chandler"
      ],
      "text": "What're we gonna do? What're we gonna do?"
    },
    {
      "type": "dialogue",
      "speakerLabel": "JOEY",
      "speakerIds": [
        "joey"
      ],
      "text": "Uh, uh, we'll flip for it. Ducks or clowns."
    },
    {
      "type": "dialogue",
      "speakerLabel": "CHANDLER",
      "speakerIds": [
        "chandler"
      ],
      "text": "Oh, we're gonna flip for the baby?"
    },
    {
      "type": "dialogue",
      "speakerLabel": "JOEY",
      "speakerIds": [
        "joey"
      ],
      "text": "You got a better idea?"
    },
    {
      "type": "dialogue",
      "speakerLabel": "CHANDLER",
      "speakerIds": [
        "chandler"
      ],
      "text": "All right, call it in the air."
    },
    {
      "type": "dialogue",
      "speakerLabel": "JOEY",
      "speakerIds": [
        "joey"
      ],
      "text": "Heads."
    },
    {
      "type": "dialogue",
      "speakerLabel": "CHANDLER",
      "speakerIds": [
        "chandler"
      ],
      "text": "Heads it is."
    },
    {
      "type": "dialogue",
      "speakerLabel": "JOEY",
      "speakerIds": [
        "joey"
      ],
      "text": "Yes! Whew!"
    },
    {
      "type": "dialogue",
      "speakerLabel": "CHANDLER",
      "speakerIds": [
        "chandler"
      ],
      "text": "We have to assign heads to something."
    },
    {
      "type": "dialogue",
      "speakerLabel": "JOEY",
      "speakerIds": [
        "joey"
      ],
      "text": "Right. Ok, ok, uh, ducks is heads, because ducks have heads."
    },
    {
      "type": "dialogue",
      "speakerLabel": "CHANDLER",
      "speakerIds": [
        "chandler"
      ],
      "text": "What kind of scary-ass clowns came to your birthday?"
    },
    {
      "type": "action",
      "text": "(on the sidewalk outside Central Perk)"
    },
    {
      "type": "dialogue",
      "speakerLabel": "RACHEL",
      "speakerIds": [
        "rachel"
      ],
      "text": "Hey."
    },
    {
      "type": "dialogue",
      "speakerLabel": "PHOEBE",
      "speakerIds": [
        "phoebe"
      ],
      "text": "Oh, hi."
    },
    {
      "type": "dialogue",
      "speakerLabel": "RACHEL",
      "speakerIds": [
        "rachel"
      ],
      "text": "Here. I thought you might be cold."
    },
    {
      "type": "dialogue",
      "speakerLabel": "PHOEBE",
      "speakerIds": [
        "phoebe"
      ],
      "text": "Thank you."
    },
    {
      "type": "dialogue",
      "speakerLabel": "RACHEL",
      "speakerIds": [
        "rachel"
      ],
      "text": "Whoa, look at you, you did pretty well."
    },
    {
      "type": "dialogue",
      "speakerLabel": "PHOEBE",
      "speakerIds": [
        "phoebe"
      ],
      "text": "Eight dollars and 27 cents. But not really, 'cause I put in the first two, just to, you know, get the ball rolling, and to make myself feel better."
    },
    {
      "type": "dialogue",
      "speakerLabel": "RACHEL",
      "speakerIds": [
        "rachel"
      ],
      "text": "Do you?"
    },
    {
      "type": "dialogue",
      "speakerLabel": "PHOEBE",
      "speakerIds": [
        "phoebe"
      ],
      "text": "No. This whole like playing-for-money thing is so not good for me. You know, I don't know, when I sang \"Su-Su-Suicide\", I got a dollar seventy-five. But then, \"Smelly Cat\", I got 25 cents and a condom. So you know, now I just feel really bad for Smelly Cat."
    },
    {
      "type": "dialogue",
      "speakerLabel": "RACHEL",
      "speakerIds": [
        "rachel"
      ],
      "text": "Well, you know, honey, I don't think everybody gets Smelly Cat. You know, I mean, if all you've ever actually had are healthy pets, then, whoosh!"
    },
    {
      "type": "dialogue",
      "speakerLabel": "PHOEBE",
      "speakerIds": [
        "phoebe"
      ],
      "text": "It's not even that. I used to do my songs because it made me happy, but now it's like, it's just all about the money."
    },
    {
      "type": "dialogue",
      "speakerLabel": "RACHEL",
      "speakerIds": [
        "rachel"
      ],
      "text": "Well, people missed you in there. And in fact, there was actually a request for \"Smelly Cat\"."
    },
    {
      "type": "dialogue",
      "speakerLabel": "PHOEBE",
      "speakerIds": [
        "phoebe"
      ],
      "text": "Really? From who?"
    },
    {
      "type": "dialogue",
      "speakerLabel": "RACHEL",
      "speakerIds": [
        "rachel"
      ],
      "text": "Well, from me. And I know it's not your big money song, but it's my favorite."
    },
    {
      "type": "dialogue",
      "speakerLabel": "KID",
      "speakerIds": [
        "kid"
      ],
      "text": "Hi. Uh, did I accidentally drop a condom in your case? It's kind of an emergency."
    },
    {
      "type": "dialogue",
      "speakerLabel": "PHOEBE",
      "speakerIds": [
        "phoebe"
      ],
      "text": "Yeah. Here you go."
    },
    {
      "type": "dialogue",
      "speakerLabel": "KID",
      "speakerIds": [
        "kid"
      ],
      "text": "Thanks a lot. Hey Christine, I got it!"
    },
    {
      "type": "action",
      "text": "(chez Monica and Rachel)"
    },
    {
      "type": "dialogue",
      "speakerLabel": "ROSS",
      "speakerIds": [
        "ross"
      ],
      "text": "I just wanna thank you for being there for me today. And I'm sorry I,I almost broke your hand."
    },
    {
      "type": "dialogue",
      "speakerLabel": "MONICA",
      "speakerIds": [
        "monica"
      ],
      "text": "That's ok. I'm sorry I poisoned you."
    },
    {
      "type": "dialogue",
      "speakerLabel": "ROSS",
      "speakerIds": [
        "ross"
      ],
      "text": "Yeah. Hey, remember the time I jammed that pencil into your hand?"
    },
    {
      "type": "dialogue",
      "speakerLabel": "MONICA",
      "speakerIds": [
        "monica"
      ],
      "text": "Remember it? What do you think this is, a freckle?"
    },
    {
      "type": "dialogue",
      "speakerLabel": "ROSS",
      "speakerIds": [
        "ross"
      ],
      "text": "Oh."
    },
    {
      "type": "dialogue",
      "speakerLabel": "MONICA",
      "speakerIds": [
        "monica"
      ],
      "text": "Wait, what about the time I hit you in the face with the Silvian's pumpkin?"
    },
    {
      "type": "dialogue",
      "speakerLabel": "ROSS",
      "speakerIds": [
        "ross"
      ],
      "text": "Oh, man. Oh, remember when I stuck that broom in your bike spokes, and you flipped over and hit your head on the curb?"
    },
    {
      "type": "dialogue",
      "speakerLabel": "MONICA",
      "speakerIds": [
        "monica"
      ],
      "text": "No. But I remember people telling me about it."
    },
    {
      "type": "dialogue",
      "speakerLabel": "ROSS",
      "speakerIds": [
        "ross"
      ],
      "text": "I hope Ben has a little sister."
    },
    {
      "type": "dialogue",
      "speakerLabel": "MONICA",
      "speakerIds": [
        "monica"
      ],
      "text": "Yeah. I hope she can kick his ass."
    },
    {
      "type": "dialogue",
      "speakerLabel": "ROSS",
      "speakerIds": [
        "ross"
      ],
      "text": "I'm gonna get a new band-aid. Hey, how 'bout the time I cut the legs off your Malibu Ken?"
    },
    {
      "type": "dialogue",
      "speakerLabel": "MONICA",
      "speakerIds": [
        "monica"
      ],
      "text": "That was you?"
    },
    {
      "type": "dialogue",
      "speakerLabel": "ROSS",
      "speakerIds": [
        "ross"
      ],
      "text": "They, uh, were infected. He wouldn't have made it."
    },
    {
      "type": "dialogue",
      "speakerLabel": "MONICA",
      "speakerIds": [
        "monica"
      ],
      "text": "Aw, my little nephew. Come here, little one. There's my little baby Ben. Hey, my little boy. Hey, he's not crying."
    },
    {
      "type": "dialogue",
      "speakerLabel": "CHANDLER",
      "speakerIds": [
        "chandler"
      ],
      "text": "(looking fearfully at Joey) Hey, he's not crying."
    },
    {
      "type": "action",
      "text": "(Ben starts crying)"
    },
    {
      "type": "dialogue",
      "speakerLabel": "JOEY",
      "speakerIds": [
        "joey"
      ],
      "text": "Yes! There's still pie."
    },
    {
      "type": "dialogue",
      "speakerLabel": "ROSS",
      "speakerIds": [
        "ross"
      ],
      "text": "I'm here. How's my little boy? Want Daddy to change your diaper? So, did you have fun with Uncle Joey and Uncle Chandler today?"
    },
    {
      "type": "dialogue",
      "speakerLabel": "JOEY",
      "speakerIds": [
        "joey"
      ],
      "text": "Oh, yeah, he rode the bus today."
    },
    {
      "type": "dialogue",
      "speakerLabel": "ROSS",
      "speakerIds": [
        "ross"
      ],
      "text": "Ohhh. Big boy, riding the bus--Hey, I have a question. How come it says Property of Human Services on his butt?"
    },
    {
      "type": "dialogue",
      "speakerLabel": "CHANDLER",
      "speakerIds": [
        "chandler"
      ],
      "text": "You, you are gonna love this."
    },
    {
      "type": "dialogue",
      "speakerLabel": "ROSS",
      "speakerIds": [
        "ross"
      ],
      "text": "Will you hold Ben for a sec? Come here. Come here."
    },
    {
      "type": "dialogue",
      "speakerLabel": "CHANDLER",
      "speakerIds": [
        "chandler"
      ],
      "text": "Stay back, I've got kiwi. Run, Joey, Run!"
    },
    {
      "type": "dialogue",
      "speakerLabel": "STEPHANIE",
      "speakerIds": [
        "stephanie"
      ],
      "text": "(singing) Smelly cat, smelly cat, what are they feeding you?"
    },
    {
      "type": "dialogue",
      "speakerLabel": "PHOEBE",
      "speakerIds": [
        "phoebe"
      ],
      "text": "No, no, no. I'm sorry. It's \"smelly cat, smel-ly cat\"."
    },
    {
      "type": "dialogue",
      "speakerLabel": "STEPHANIE",
      "speakerIds": [
        "stephanie"
      ],
      "text": "Smelly cat, smel-ly cat..."
    },
    {
      "type": "dialogue",
      "speakerLabel": "PHOEBE",
      "speakerIds": [
        "phoebe"
      ],
      "text": "Better. Yeah."
    },
    {
      "type": "dialogue",
      "speakerLabel": "STEPHANIE",
      "speakerIds": [
        "stephanie"
      ],
      "text": "Yeah?"
    },
    {
      "type": "dialogue",
      "speakerLabel": "PHOEBE",
      "speakerIds": [
        "phoebe"
      ],
      "text": "Yeah, much better. And you know what, don't feel bad, because it's a hard song."
    },
    {
      "type": "dialogue",
      "speakerLabel": "STEPHANIE",
      "speakerIds": [
        "stephanie"
      ],
      "text": "Yeah."
    },
    {
      "type": "dialogue",
      "speakerLabel": "PHOEBE",
      "speakerIds": [
        "phoebe"
      ],
      "text": "You wanna try it again?"
    },
    {
      "type": "dialogue",
      "speakerLabel": "STEPHANIE",
      "speakerIds": [
        "stephanie"
      ],
      "text": "Yeah. From the top?"
    },
    {
      "type": "dialogue",
      "speakerLabel": "PHOEBE",
      "speakerIds": [
        "phoebe"
      ],
      "text": "Ok, there is no top. That's the beauty of Smelly Cat. Um, why don't you just follow me?"
    },
    {
      "type": "dialogue",
      "speakerLabel": "STEPHANIE",
      "speakerIds": [
        "stephanie"
      ],
      "text": "Ok."
    },
    {
      "type": "dialogue",
      "speakerLabel": "PHOEBE",
      "speakerIds": [
        "phoebe"
      ],
      "text": "Mmmm hmmm."
    },
    {
      "type": "dialogue",
      "speakerLabel": "TOGETHER",
      "speakerIds": [
        "together"
      ],
      "text": "Smelly Cat, Smelly Cat, what are they feeding you? Smelly Cat, Smelly Cat, it's not your fault."
    },
    {
      "type": "dialogue",
      "speakerLabel": "PHOEBE",
      "speakerIds": [
        "phoebe"
      ],
      "text": "That's too much. Sorry."
    },
    {
      "type": "scene",
      "text": "END"
    }
  ]
}
